__pycache__/
*.pyc
.venv/
.vscode/
*.log

# transcription outputs that may land in the repo during testing
live_*.txt
*.tmp.*

# secrets — never commit the API key
groq_api_key.txt

# local cloud opt-in marker (a per-machine choice, not a repo default)
allow_cloud

# personal voice fingerprints
speaker_profiles.json

# per-user GUI preferences
.settings.json

# build / packaging / test artifacts
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# mobile app: the generated React Native project's deps/build (the app/ source
# will be committed once initialized; these never are)
mobile/app/node_modules/
mobile/app/android/.gradle/
mobile/app/android/app/build/
mobile/app/ios/Pods/
mobile/**/*.keystore
